# Database Configuration
DATASOURCE_URL=postgresql+asyncpg://localhost:5432/bookstore
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=postgres
DATASOURCE_DB=bookstore

# Database Connection Pool Configuration
# DB_POOL_MAX_SIZE=5
# DB_POOL_MIN_IDLE=1

# API Documentation
ENABLE_SWAGGER_UI=true
ENABLE_API_DOCS=true

# Logging
LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG

# Server Configuration
SERVER_PORT=8080

# Docker Configuration for Testcontainers with Colima
#DOCKER_HOST=unix:///Users/$USER/.colima/default/docker.sock
#TESTCONTAINERS_HUB_IMAGE_NAME_PREFIX=docker.io/

# OAuth2/UAA Configuration
# JWT verification endpoints
OAUTH2_JWK_URI=https://your-idp.example.com/.well-known/jwks.json
OAUTH2_ISSUER_URI=https://your-idp.example.com/oauth/token
OAUTH2_AUDIENCE=bookstore-api

# Optional: Additional UAA-specific configuration
# UAA_LOGIN_URL=https://your-idp.example.com/oauth/authorize
# UAA_TOKEN_URL=https://your-idp.example.com/oauth/token
# UAA_USER_INFO_URL=https://your-idp.example.com/userinfo
